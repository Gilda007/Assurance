                widget.setText(str(getattr(v, attr, "")) if getattr(v, attr, None) else "")

            # --- 2. NOMBRES SIMPLES (QLineEdit avec chiffres) ---
            if hasattr(v, 'annee') and v.annee:
                self.annee_input.setText(str(v.annee))

